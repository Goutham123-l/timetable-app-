generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum SubjectType {
  THEORY
  LAB
}

enum RoomType {
  CLASSROOM
  LAB
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  teacherId Int?     @unique
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
  sectionId Int?
  section   Section? @relation(fields: [sectionId], references: [id])
  createdAt DateTime @default(now())
}

model Department {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  code     String    @unique
  teachers Teacher[]
  sections Section[]
}

model Section {
  id           Int          @id @default(autoincrement())
  name         String
  year         Int
  departmentId Int
  department   Department   @relation(fields: [departmentId], references: [id])
  assignments  Assignment[]
  entries      TimetableEntry[]
  users        User[]
  daysOff      SectionDayOff[]

  @@unique([name, year, departmentId])
}

model Subject {
  id          Int          @id @default(autoincrement())
  name        String
  code        String       @unique
  type        SubjectType  @default(THEORY)
  weeklyHours Int          @default(3)
  year        Int?         // which year this subject belongs to (1-4). Null = common/any year.
  alwaysLastPeriod Boolean @default(false) // e.g. Library/Sports — always scheduled as the day's last period
  assignments Assignment[]
}

model Teacher {
  id              Int          @id @default(autoincrement())
  name            String
  departmentId    Int
  department      Department   @relation(fields: [departmentId], references: [id])
  designation     String?
  maxPeriodsDay   Int          @default(6)
  maxPeriodsWeek  Int          @default(24)
  user            User?
  assignments     Assignment[]
  entries         TimetableEntry[]
}

model Classroom {
  id         Int      @id @default(autoincrement())
  roomNumber String   @unique
  capacity   Int      @default(60)
  type       RoomType @default(CLASSROOM)
  entries    TimetableEntry[]
}

// The manual table: Teacher + Subject + Section + Periods/Week
model Assignment {
  id            Int      @id @default(autoincrement())
  teacherId     Int
  teacher       Teacher  @relation(fields: [teacherId], references: [id])
  subjectId     Int
  subject       Subject  @relation(fields: [subjectId], references: [id])
  sectionId     Int
  section       Section  @relation(fields: [sectionId], references: [id])
  periodsPerWeek Int
  coTeacherIds  Int[]    @default([]) // extra teachers co-present for the same lab session (e.g. 2-3 teachers per lab)
  createdAt     DateTime @default(now())

  @@unique([teacherId, subjectId, sectionId])
}

model WorkingDay {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  order   Int     @unique
  active  Boolean @default(true)
  entries TimetableEntry[]
  sectionDaysOff SectionDayOff[]
}

// Lets specific sections skip specific days even though the day is
// generally active college-wide (e.g. CSE 3rd Year has no Saturday classes
// while CSE 1st Year does).
model SectionDayOff {
  id        Int        @id @default(autoincrement())
  sectionId Int
  section   Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  dayId     Int
  day       WorkingDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@unique([sectionId, dayId])
}

model Period {
  id        Int      @id @default(autoincrement())
  index     Int      @unique
  label     String
  startTime String
  endTime   String
  isLunch   Boolean  @default(false)
  entries   TimetableEntry[]
}

model TimetableEntry {
  id          Int      @id @default(autoincrement())
  sectionId   Int
  section     Section  @relation(fields: [sectionId], references: [id])
  teacherId   Int
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  coTeacherIds Int[]   @default([]) // additional teachers co-present for this session
  subjectId   Int
  dayId       Int
  day         WorkingDay @relation(fields: [dayId], references: [id])
  periodId    Int
  period      Period   @relation(fields: [periodId], references: [id])
  classroomId Int?
  classroom   Classroom? @relation(fields: [classroomId], references: [id])
  locked      Boolean  @default(false)

  @@unique([sectionId, dayId, periodId])
  @@unique([teacherId, dayId, periodId])
}
